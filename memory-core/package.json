{
  "name": "@mirror-abyss/memory-core",
  "version": "0.1.0",
  "description": "Reference implementation of the Mirror Abyss Protocol MA-1 (Memory Continuity) — episodic capture, indexing, recall, and context assembly. Draft 0.1.0.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "agent",
    "memory",
    "episodic-memory",
    "context-assembly",
    "mirror-abyss",
    "ma-1",
    "protocol"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.3.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
