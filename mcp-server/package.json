{
  "name": "@mirror-abyss/ma1-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing the Mirror Abyss MA-1 memory operations (capture / recall / assemble) to any MCP-compatible agent host.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ma1-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agent",
    "memory",
    "episodic-memory",
    "mirror-abyss",
    "ma-1"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mirror-abyss/memory-core": "file:../memory-core",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.3.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
